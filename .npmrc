# SilkPlot workspace settings
# Keep the dependency tree flat and deterministic for the monorepo.
save-exact=false
# The supported toolchain is declared once, in the root package.json `engines`
# field, and enforced here: with `engine-strict`, `npm ci` and `npm install`
# FAIL on an unsupported Node or npm rather than warning. `.nvmrc` is the single
# repository tool-version file (Node), and CI reads that same file. There is
# deliberately no `packageManager` field: Corepack pinning an exact npm on top
# of an `engines` range is a second, competing mechanism, and the two had already
# drifted apart.
engine-strict=true
# Public packages publish under the @silkplot scope.
# access=public
