{
  "name": "silkplot",
  "version": "0.1.0",
  "private": true,
  "description": "SilkPlot — an open-source Solid + D3 visualization library. D3 computes, Solid renders.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/SilkPlot/sp-graph#readme",
  "type": "module",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "packages/*",
    "playground"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b && npm run typecheck:tests",
    "typecheck:tests": "tsc -p packages/core/tsconfig.test.json && tsc -p packages/theme/tsconfig.test.json && tsc -p packages/solid/tsconfig.test.json && tsc -p packages/charts/tsconfig.test.json",
    "lint": "biome lint --error-on-warnings .",
    "dev": "npm run dev --workspace playground",
    "clean": "tsc -b --clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "perf:hover": "node scripts/measure-hover-frames.mjs",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@solidjs/testing-library": "^0.8.10",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "playwright": "^1.61.1",
    "solid-js": "^1.9.14",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.10"
  }
}
