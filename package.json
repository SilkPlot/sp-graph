{
  "name": "silkplot",
  "version": "0.3.0-next.0",
  "private": true,
  "description": "SilkPlot — an open-source Solid + D3 visualization library. D3 computes, Solid renders.",
  "license": "Apache-2.0",
  "homepage": "https://silkplot.com",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.5.1"
  },
  "workspaces": [
    "packages/*",
    "playground",
    "site"
  ],
  "scripts": {
    "build": "npm run clean && tsc -b",
    "build:dist": "npm run build:dist --workspaces --if-present",
    "build:playground": "npm run build --workspace @silkplot/playground",
    "build:site": "npm run build --workspace @silkplot/site",
    "dev:site": "npm run dev --workspace @silkplot/site",
    "typecheck": "tsc -b && npm run typecheck:tests && npm run typecheck:docs",
    "typecheck:tests": "tsc -p packages/core/tsconfig.test.json && tsc -p packages/theme/tsconfig.test.json && tsc -p packages/solid/tsconfig.test.json && tsc -p packages/charts/tsconfig.test.json && tsc -p playground/tsconfig.test.json && tsc -p site/tsconfig.test.json && tsc -p test/visual/tsconfig.json && tsc -p test/perf/tsconfig.json",
    "typecheck:docs": "tsc -p docs/examples/tsconfig.json",
    "lint": "biome lint --error-on-warnings .",
    "dev": "npm run dev --workspace playground",
    "clean": "node scripts/clean.mjs",
    "test": "vitest run",
    "gate:accessibility": "node scripts/accessibility-gate.mjs",
    "gate:build-hygiene": "node scripts/build-hygiene-gate.mjs",
    "gate:duplication-scope": "node scripts/duplication-scope-gate.mjs",
    "gate:visual-baselines": "node scripts/visual-baseline-guard.mjs",
    "gate:typecheck-coverage": "node scripts/typecheck-coverage-gate.mjs",
    "gate:public-surface": "node scripts/public-surface-gate.mjs",
    "release:verify": "node scripts/release-verify.mjs",
    "release:verify:manifests": "node scripts/release-verify.mjs --no-consumer",
    "audit:prod": "npm audit --omit=dev --audit-level=low",
    "audit:dev": "npm audit --audit-level=low",
    "test:accessibility": "node scripts/accessibility-gate.mjs --run",
    "test:coverage": "vitest run --coverage",
    "perf:hover": "node scripts/measure-hover-frames.mjs",
    "probe:detection": "node scripts/detection-probes.mjs",
    "test:watch": "vitest",
    "gate:probe-residue": "node scripts/probe-residue-gate.mjs",
    "prepare": "git config core.hooksPath .githooks",
    "gate:stated-facts": "node scripts/stated-facts-gate.mjs",
    "dev:perf": "vite --config test/perf/vite.config.ts",
    "perf:workload": "node scripts/measure-workload-frames.mjs",
    "perf:decimation": "node scripts/score-decimation.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@solidjs/testing-library": "^0.8.10",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild-plugin-solid": "^0.6.0",
    "playwright": "^1.61.1",
    "solid-js": "^1.9.14",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vite-plugin-solid": "^2.11.13",
    "vitest": "^4.1.10"
  }
}
