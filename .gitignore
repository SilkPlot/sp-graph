# Dependencies
node_modules/

# Build output
dist/
.tsbuild/
*.tsbuildinfo

# Vite
.vite/
playground/dist/
playground/.tsbuild/

# Generated config output. `vite.config.ts` / `vitest.config.ts` are the sources;
# a compiled `.js` beside one WINS Vite's config search, so a tracked build
# artifact here silently decides what the build does. Only the source is tracked.
playground/vite.config.js
playground/vite.config.js.map
playground/vite.config.d.ts
playground/vite.config.d.ts.map
vitest.config.js
vitest.config.js.map
vitest.config.d.ts
vitest.config.d.ts.map

# Release staging — `npm pack` tarballs
*.tgz
.release-staging/

# Test artifacts — browser-mode failure screenshots/attachments, coverage
**/__screenshots__/
.vitest-attachments/
coverage/

# Agent tooling
.claude/

# Logs
*.log
npm-debug.log*

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

# Env
.env
.env.local

# Codacy CLI local state. `.codacy/codacy.yaml` IS tracked — it pins the tool
# versions so a local run and a CI run compare like for like. Everything else
# here is generated on `codacy-cli init`/`install`: per-tool configs derived
# from the server settings, the installed-runtime manifest, and logs. Machine
# state, not decisions.
.codacy/tools-configs/
.codacy/cli-config.yaml
.codacy/logs/
.codacy/.gitignore
