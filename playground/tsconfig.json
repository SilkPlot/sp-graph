{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    // NOT `./dist`. `dist` is Vite's bundle output; `tsc -b` is a validation
    // gate here, not a packaging step. Sharing one directory made each
    // producer's leftovers look like the other's product, which is how stale
    // output survived a rebuild unnoticed.
    "outDir": "./.tsbuild",
    "types": ["vite/client"],
    "noEmit": false
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "references": [
    { "path": "../packages/core" },
    { "path": "../packages/solid" },
    { "path": "../packages/charts" },
    { "path": "../packages/calendar" },
    { "path": "../packages/theme" }
  ]
}
