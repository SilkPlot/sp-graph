{
  "name": "@silkplot/core",
  "version": "0.2.0-next.1",
  "description": "SilkPlot core — pure D3-backed math for visualization. No Solid, no DOM.",
  "license": "Apache-2.0",
  "homepage": "https://silkplot.pages.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SilkPlot/sp-graph.git",
    "directory": "packages/core"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "src",
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "build:dist": "tsup && tsc -p tsconfig.dist.json",
    "prepack": "npm run build:dist"
  },
  "dependencies": {
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "d3-delaunay": "^6.0.4",
    "d3-format": "^3.1.2",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "d3-time-format": "^4.1.0"
  },
  "devDependencies": {
    "@types/d3-delaunay": "^6.0.4",
    "@types/d3-format": "^3.0.4",
    "@types/d3-time-format": "^4.0.3",
    "typescript": "^7.0.2"
  }
}
