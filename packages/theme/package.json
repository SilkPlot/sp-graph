{
  "name": "@silkplot/theme",
  "version": "0.2.0-next.1",
  "description": "SilkPlot theme — design tokens as objects + CSS custom properties. Motion/contrast-aware.",
  "license": "Apache-2.0",
  "homepage": "https://silkplot.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SilkPlot/sp-graph.git",
    "directory": "packages/theme"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "src",
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "build:dist": "tsup && tsc -p tsconfig.dist.json",
    "prepack": "npm run build:dist"
  },
  "dependencies": {
    "d3-scale-chromatic": "^3.1.0"
  },
  "devDependencies": {
    "@types/d3-scale-chromatic": "^3.1.0",
    "typescript": "^7.0.2"
  }
}
