{
  "$schema": "https://json.schemastore.org/tsconfig",
  // See `packages/core/tsconfig.test.json` for why `test/` needs its own config
  // and why `src` is included alongside it.
  //
  // `theme` emits CSS as strings and holds no DOM code, so it keeps the DOM-free
  // `lib` its package tsconfig uses.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "lib": ["ES2022"],
    "types": []
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
