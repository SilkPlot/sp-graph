{
  "name": "@silkplot/charts",
  "version": "0.2.0-next.0",
  "description": "SilkPlot charts — composed chart components (LineChart and more). D3 computes, Solid renders.",
  "license": "Apache-2.0",
  "homepage": "https://silkplot.pages.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SilkPlot/sp-graph.git",
    "directory": "packages/charts"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "src",
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "solid": "./src/index.tsx",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "build:dist": "tsup && tsc -p tsconfig.dist.json",
    "prepack": "npm run build:dist"
  },
  "peerDependencies": {
    "solid-js": "^1.9.14"
  },
  "dependencies": {
    "@silkplot/core": "0.2.0-next.0",
    "@silkplot/solid": "0.2.0-next.0"
  },
  "devDependencies": {
    "solid-js": "^1.9.14",
    "typescript": "^7.0.2"
  }
}
