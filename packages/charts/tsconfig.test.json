{
  "$schema": "https://json.schemastore.org/tsconfig",
  // See `packages/core/tsconfig.test.json` for why `test/` needs its own config
  // and why `src` is included alongside it.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "types": []
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "test/**/*.ts", "test/**/*.tsx"]
}
